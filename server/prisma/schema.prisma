generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum ApplicationStatus {
  NEW
  REVIEWING
  REJECTED
  HIRED
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
}

enum SeniorityLevel {
  JUNIOR
  MID
  SENIOR
  LEAD
}

enum PaymentPurpose {
  OFFER
  PROMOTION
}

enum PaymentStatus {
  PENDING
  PAID
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  role          Role     @default(CANDIDATE)
  isBanned      Boolean  @default(false)
  emailVerified Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  firstName String?
  lastName  String?
  phone     String?

  candidateProfile       CandidateProfile?
  companyProfile         CompanyProfile?
  applications           Application[]
  savedOffers            SavedOffer[]
  employerConversations  Conversation[] @relation("EmployerConversations")
  candidateConversations Conversation[] @relation("CandidateConversations")
  sentMessages           Message[]      @relation("SentMessages")
  reports                Report[]
}

model CandidateProfile {
  id     Int     @id @default(autoincrement())
  userId Int     @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  cvUrl  String?
  bio    String?
}

model CompanyProfile {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName  String
  logoUrl      String?
  description  String?
  website      String?
  location     String?
  nip          String? @unique
  companyEmail String?

  jobOffers   JobOffer[]
  payments    Payment[]
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  jobOffers JobOffer[]
}

model JobOffer {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text

  salaryMin  Int?
  salaryMax  Int?
  currency   String   @default("PLN")
  location   String
  contract   String   @default("B2B")
  workMode   WorkMode

  isActive   Boolean  @default(false)
  isApproved Boolean  @default(false)
  isPromoted Boolean  @default(false)
  isPaidOffer Boolean @default(false)
  views      Int      @default(0)
  validUntil DateTime

  skills     String[] @default([])
  seniority  SeniorityLevel?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companyId  Int
  company    CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  applications Application[]
  savedBy      SavedOffer[]
  reports      Report[]
  payments     Payment[]
}

model Application {
  id        Int               @id @default(autoincrement())
  appliedAt DateTime          @default(now())
  status    ApplicationStatus @default(NEW)

  startDate          String?
  contractType       String?
  expectedSalary     Int?
  coverMessage       String?  @db.Text
  cvFileName         String?
  additionalFileName String?
  customCvUrl        String?

  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobOfferId Int
  jobOffer   JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  conversations Conversation[]

  @@unique([userId, jobOfferId])
}

model Conversation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  employerId  Int
  employer    User @relation("EmployerConversations", fields: [employerId], references: [id], onDelete: Cascade)

  candidateId Int
  candidate   User @relation("CandidateConversations", fields: [candidateId], references: [id], onDelete: Cascade)

  applicationId Int?
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  messages Message[]

  @@unique([employerId, candidateId, applicationId])
}

model Message {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  content   String   @db.Text

  senderId Int
  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Report {
  id          Int          @id @default(autoincrement())
  createdAt   DateTime     @default(now())
  reason      String
  description String?      @db.Text
  status      ReportStatus @default(PENDING)

  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobOfferId Int
  jobOffer   JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([userId, jobOfferId])
}

model SavedOffer {
  id      Int      @id @default(autoincrement())
  savedAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobOfferId Int
  jobOffer   JobOffer @relation(fields: [jobOfferId], references: [id], onDelete: Cascade)

  @@unique([userId, jobOfferId])
}

model StaticPage {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  title     String
  content   String   @db.Text
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  subscribedAt DateTime @default(now())
}

enum ContactStatus {
  NEW
  READ
}

model ContactMessage {
  id        Int           @id @default(autoincrement())
  createdAt DateTime      @default(now())
  name      String
  email     String
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Brak integracji z prawdziwą bramką płatności (np. Przelewy24/Stripe) — status
// jest ustawiany na PAID synchronicznie przy "zatwierdzeniu" w serwisie, bez
// faktycznego pobrania pieniędzy. Pole PENDING zostawione pod przyszłą, prawdziwą
// integrację (np. przejście PENDING -> PAID dopiero po webhooku od dostawcy płatności).
model Payment {
  id         Int            @id @default(autoincrement())
  purpose    PaymentPurpose
  amount     Int
  status     PaymentStatus  @default(PENDING)
  createdAt  DateTime       @default(now())
  paidAt     DateTime?

  companyId  Int
  company    CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  jobOfferId Int?
  jobOffer   JobOffer?      @relation(fields: [jobOfferId], references: [id], onDelete: SetNull)
}
