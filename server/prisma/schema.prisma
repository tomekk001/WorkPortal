generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum ApplicationStatus {
  NEW
  REVIEWING
  REJECTED
  HIRED
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(CANDIDATE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String?
  lastName  String?
  phone     String?

  candidateProfile       CandidateProfile?
  companyProfile         CompanyProfile?
  applications           Application[]
  savedOffers            SavedOffer[]
  employerConversations  Conversation[] @relation("EmployerConversations")
  candidateConversations Conversation[] @relation("CandidateConversations")
  sentMessages           Message[]      @relation("SentMessages")
}

model CandidateProfile {
  id     Int     @id @default(autoincrement())
  userId Int     @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  cvUrl  String?
  bio    String?
}

model CompanyProfile {
  id          Int     @id @default(autoincrement())
  userId      Int     @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String
  logoUrl     String?
  description String?
  website     String?
  location    String?

  jobOffers   JobOffer[]
}

model Category {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  jobOffers JobOffer[]
}

model JobOffer {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text

  salaryMin  Int?
  salaryMax  Int?
  currency   String   @default("PLN")
  location   String
  contract   String   @default("B2B")
  workMode   WorkMode

  isActive   Boolean  @default(false)
  isPromoted Boolean  @default(false)
  views      Int      @default(0)
  validUntil DateTime

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  companyId  Int
  company    CompanyProfile @relation(fields: [companyId], references: [id])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  applications Application[]
  savedBy      SavedOffer[]
}

model Application {
  id        Int               @id @default(autoincrement())
  appliedAt DateTime          @default(now())
  status    ApplicationStatus @default(NEW)

  startDate          String?
  contractType       String?
  expectedSalary     Int?
  coverMessage       String?  @db.Text
  cvFileName         String?
  additionalFileName String?
  customCvUrl        String?

  userId     Int
  user       User     @relation(fields: [userId], references: [id])

  jobOfferId Int
  jobOffer   JobOffer @relation(fields: [jobOfferId], references: [id])

  conversations Conversation[]

  @@unique([userId, jobOfferId])
}

model Conversation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  employerId  Int
  employer    User @relation("EmployerConversations", fields: [employerId], references: [id])

  candidateId Int
  candidate   User @relation("CandidateConversations", fields: [candidateId], references: [id])

  applicationId Int?
  application   Application? @relation(fields: [applicationId], references: [id])

  messages Message[]

  @@unique([employerId, candidateId, applicationId])
}

model Message {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  content   String   @db.Text

  senderId Int
  sender   User @relation("SentMessages", fields: [senderId], references: [id])

  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model SavedOffer {
  id      Int      @id @default(autoincrement())
  savedAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  jobOfferId Int
  jobOffer   JobOffer @relation(fields: [jobOfferId], references: [id])

  @@unique([userId, jobOfferId])
}
