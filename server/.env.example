# Baza danych
DATABASE_URL="postgresql://user:password@localhost:5432/work_portal?schema=public"

# Sekret do podpisywania tokenów JWT — wygeneruj losowy ciąg (np. `openssl rand -hex 48`)
JWT_SECRET=""

# Publiczny adres frontendu — używany do budowania linków w sitemap.xml/robots.txt
# oraz do zawężenia CORS w produkcji. W developmencie: http://localhost:5180
PUBLIC_APP_URL="http://localhost:5180"

# --- Wysyłka e-maili (reset hasła, weryfikacja adresu firmowego) ---
# Jeśli SMTP_HOST nie jest ustawiony, serwer używa testowej skrzynki Ethereal
# (maile NIE trafiają do prawdziwych adresatów — tylko podgląd w logach).
# Resend (smtp.resend.com): SMTP_USER=resend, SMTP_PASS=<Twój klucz API>
# Gmail (smtp.gmail.com): wymaga "hasła aplikacji", nie zwykłego hasła do konta
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"WorkPortal\" <no-reply@workportal.pl>"

# --- Przechowywanie plików (logo firm, CV kandydatów) ---
# Jeśli poniższe zmienne nie są ustawione, pliki trafiają na lokalny dysk
# (uploads/) — działa tylko do developmentu, bo większość hostingów kasuje
# lokalne pliki przy każdym redeployu. W produkcji ustaw konto Cloudflare R2
# (S3-kompatybilne, darmowe do 10GB) i uzupełnij poniższe.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
# Publiczny adres bucketu (własna domena albo *.r2.dev) — bez końcowego /
R2_PUBLIC_URL=""
